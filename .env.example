# ========== 对话（主 + 备用） ==========
# DeepSeek 主对话：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-xxxxxxxx
DEEPSEEK_MODEL=deepseek-chat

# 火山方舟 Fallback（OpenAI 兼容）：https://console.volcengine.com/ark
# 在控制台创建「推理接入点」后，把接入点 ID 填到 ENDPOINT_ID
VOLCENGINE_ARK_API_KEY=xxxxxxxx
VOLCENGINE_ARK_ENDPOINT_ID=ep-xxxxxxxx
VOLCENGINE_ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ========== 豆包语音（TTS + STT） ==========
# 控制台：https://console.volcengine.com/speech
VOLCENGINE_SPEECH_APP_ID=你的AppID
VOLCENGINE_SPEECH_ACCESS_TOKEN=你的AccessToken
VOLCENGINE_SPEECH_CLUSTER=volcano_tts

# 可选：各 NPC 音色（在控制台「音色列表」查 voice_type，需支持日语）
# 示例：BV702_streaming（多语种女声）、BV524_streaming（日语男声）
VOLCENGINE_TTS_VOICE_MISAKI=BV702_streaming
VOLCENGINE_TTS_VOICE_KIMURA=BV524_streaming
VOLCENGINE_TTS_VOICE_TAISHO=BV524_streaming

# TTS 策略：auto=有火山配置则优先火山，失败回退 Edge | volcano | edge
TTS_PROVIDER=auto

# STT 语种优先级（仅允许 ja,en,zh），逗号分隔，默认 ja,en,zh
VOLCENGINE_STT_LANGUAGES=ja,en,zh
